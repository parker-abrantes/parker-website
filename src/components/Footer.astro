---
import SocialLinks from './SocialLinks.astro';
---

<footer>
  <div class="footer-inner">
    <div class="footer-left">
      <span class="label">Parker Abrantes</span>
      <p>Aerospace engineer. Writer. Builder.<br />Melbourne, FL — from North Attleboro, MA.</p>
      <div class="footer-socials">
        <SocialLinks direction="row" />
      </div>
    </div>
    <nav class="footer-nav">
      <a href="/about">About</a>
      <a href="/work">Work</a>
      <a href="/projects">Projects</a>
      <a href="/writing">Writing</a>
      <a href="/now">Now</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
  <div class="footer-bottom">
    <span class="label">Built with Astro · {new Date().getFullYear()}</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 3rem 2rem 2rem;
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .footer-left p {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--dim);
    line-height: 1.6;
  }

  .footer-socials {
    margin-top: 1.25rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-end;
  }

  .footer-nav a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--text);
    opacity: 1;
  }

  .footer-bottom {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .footer-nav { align-items: flex-start; }
  }
</style>
