---
---

<div id="terminal-hook" aria-hidden="true">
  <div id="terminal-lines"></div>
  <button id="terminal-skip">skip</button>
</div>

<style>
  #terminal-hook {
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease;
  }

  #terminal-hook.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  #terminal-lines {
    font-family: var(--font-mono);
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    color: var(--mono);
    line-height: 2;
    min-width: 36ch;
  }

  #terminal-lines .prompt {
    color: var(--muted);
  }

  #terminal-lines .error {
    color: #ff6b6b;
  }

  #terminal-lines .success {
    color: var(--accent);
  }

  #terminal-lines .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.1em;
    background: var(--mono);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  #terminal-skip {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: none;
    border: 1px solid var(--border);
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    letter-spacing: 0.08em;
    transition: border-color 0.15s, color 0.15s;
  }

  #terminal-skip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const hook   = document.getElementById('terminal-hook')!;
  const lines  = document.getElementById('terminal-lines')!;
  const skip   = document.getElementById('terminal-skip')!;

  const sequence = [
    { text: '$ whoami',                         class: 'prompt',  delay: 400  },
    { text: "  error: user 'parker' not found", class: 'error',   delay: 900  },
    { text: '$ --override --force',             class: 'prompt',  delay: 700  },
    { text: '  > access granted',               class: 'success', delay: 600  },
    { text: '  > loading parker abrantes...',   class: 'success', delay: 800  },
  ];

  let dismissed = false;

  function dismiss() {
    if (dismissed) return;
    dismissed = true;
    hook.classList.add('fade-out');
    setTimeout(() => hook.remove(), 650);
  }

  skip.addEventListener('click', dismiss);

  async function run() {
    for (const step of sequence) {
      if (dismissed) return;
      await new Promise(r => setTimeout(r, step.delay));
      if (dismissed) return;

      const line = document.createElement('div');
      line.className = step.class;
      line.textContent = step.text;
      lines.appendChild(line);
    }

    await new Promise(r => setTimeout(r, 900));
    dismiss();
  }

  run();
</script>
