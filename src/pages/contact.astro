---
import Base from '../layouts/Base.astro';
import { links } from '../config/links';
---

<Base title="Contact" description="Get in touch with Parker Abrantes.">
  <main class="contact-main">

    <header class="contact-header">
      <p class="label" style="color: var(--accent); margin-bottom: 1rem;">Contact</p>
      <h1>Get in touch</h1>
      <p class="contact-sub">
        Open to research collaborations, internships, technical writing,
        student project documentation, and strange useful conversations.
      </p>
    </header>

    <div class="contact-links">
      <a href={`mailto:${links.email}`} class="contact-item">
        <span class="label">Email</span>
        <span>{links.email}</span>
      </a>
      <a href={links.linkedin} target="_blank" rel="noopener" class="contact-item">
        <span class="label">LinkedIn</span>
        <span>parker-abrantes</span>
      </a>
      <a href={links.github} target="_blank" rel="noopener" class="contact-item">
        <span class="label">GitHub</span>
        <span>parker-abrantes</span>
      </a>
      <a href={links.substack} target="_blank" rel="noopener" class="contact-item">
        <span class="label">Substack</span>
        <span>Ground Control</span>
      </a>
      <a href={links.instagram} target="_blank" rel="noopener" class="contact-item">
        <span class="label">Instagram</span>
        <span>@parker.abrantes</span>
      </a>
      <a href={links.twitter} target="_blank" rel="noopener" class="contact-item">
        <span class="label">X / Twitter</span>
        <span>@parkerabrantes</span>
      </a>
      <a href={links.youtube} target="_blank" rel="noopener" class="contact-item">
        <span class="label">YouTube</span>
        <span>Parker Abrantes</span>
      </a>
    </div>

    <div class="fundraiser-box">
      <div class="fundraiser-label">
        <span class="status-badge">Active Fundraiser</span>
      </div>
      <h2>Philadelphia Half Marathon</h2>
      <p>
        Running the Philadelphia Half Marathon to raise money for the Emily Whitehead Foundation —
        pediatric cancer research and CAR T-cell therapy. Emily was the first pediatric patient
        treated with CAR T-cell therapy.
      </p>
      <div class="fundraiser-links">
        <a href={links.fundraiser.donate} target="_blank" rel="noopener" class="btn-donate">Donate →</a>
        <a href={links.fundraiser.page} target="_blank" rel="noopener" class="btn-page">View fundraiser page</a>
      </div>
    </div>

    <div class="contact-note">
      <p>
        I'm a sophomore at Florida Tech. I don't have all the answers and I'm not pretending to.
        But I show up, I do the work, and I respond to emails.
      </p>
    </div>

  </main>
</Base>

<style>
  .contact-main {
    max-width: 640px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
  }

  .contact-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .contact-sub {
    margin-top: 1rem;
    color: var(--dim);
    font-size: 1rem;
    line-height: 1.75;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 3rem;
  }

  .contact-item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: color 0.15s;
  }

  .contact-item:hover { color: var(--accent); opacity: 1; }
  .contact-item:hover .label { color: var(--accent); }

  .contact-item .label {
    min-width: 100px;
    color: var(--muted);
    transition: color 0.15s;
  }

  .contact-item span:last-child { font-size: 1rem; }

  /* Fundraiser */
  .fundraiser-box {
    border: 1px solid var(--accent);
    padding: 1.75rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fundraiser-label { margin-bottom: 0.25rem; }

  .status-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.15rem 0.5rem;
  }

  .fundraiser-box h2 { font-size: 1.3rem; }

  .fundraiser-box p {
    font-size: 0.95rem;
    color: var(--dim);
    line-height: 1.7;
  }

  .fundraiser-links {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .btn-donate {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    background: var(--accent);
    color: var(--bg);
    padding: 0.5rem 1.25rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .btn-donate:hover { opacity: 0.85; }

  .btn-page {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .btn-page:hover { color: var(--text); opacity: 1; }

  .contact-note {
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .contact-note p {
    font-size: 0.95rem;
    color: var(--dim);
    line-height: 1.75;
    font-style: italic;
  }
</style>
