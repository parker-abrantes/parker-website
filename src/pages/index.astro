---
import Base from '../layouts/Base.astro';
---

<Base>
  <main style="padding: 4rem 2rem;">
    <h1>Parker <span class="accent">Abrantes</span></h1>
    <p style="margin-top: 1.5rem; color: var(--dim);">Design system check — fonts, palette, and layout.</p>
    <hr />
    <p>Body text in Lora. Warm off-white on midnight blue.</p>
    <p style="margin-top: 1rem;"><code>JetBrains Mono for code and terminal text.</code></p>
    <p style="margin-top: 1rem;" class="accent">Gold accent color.</p>
    <p style="margin-top: 1rem;" class="dim">Dim secondary text.</p>
    <p style="margin-top: 1rem;" class="label">Label / tag style — uppercase tracked mono</p>
  </main>
</Base>
