---
import Base from '../layouts/Base.astro';
import TerminalHook from '../components/TerminalHook.astro';
import PhotoScatter from '../components/PhotoScatter.astro';
---

<Base>
  <PhotoScatter />
  <TerminalHook />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="label" style="margin-bottom: 1.25rem;">Parker Abrantes</p>
      <h1>Barista.<br /><em>Rocket scientist.</em><br />Still figuring out the difference.</h1>
      <p class="tagline">
        Aerospace engineering student at Florida Tech. I build nuclear finance models,
        study autonomous traffic systems, train for a half marathon, and write essays
        about what it costs to become a person while still being one.
        Melbourne, FL — from North Attleboro, MA.
      </p>
      <div class="hero-links">
        <a href="/work">Current Work</a>
        <a href="/writing">Read Writing</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </section>

  <!-- Pull quote -->
  <section class="pull-quote-section">
    <blockquote class="hero-pull-quote">
      "comparison is abandoning the only self you will ever be"
    </blockquote>
  </section>

  <!-- Section Cards -->
  <section class="cards-section">
    <div class="cards-grid">
      <a href="/work#research" class="card">
        <span class="card-label label">Research</span>
        <h3>Edge-AI &amp; Robotics</h3>
        <p>Traffic validation datasets, VRU safety, Foxglove visualization, and sensor pipelines in the Aerospace Systems Lab.</p>
        <span class="card-arrow">→</span>
      </a>
      <a href="/work#energy" class="card">
        <span class="card-label label">Energy Systems</span>
        <h3>Nuclear Finance &amp; Deployment</h3>
        <p>Why advanced reactors struggle under private financing — discount rates, DSCR, construction timelines, and what it takes to make them real.</p>
        <span class="card-arrow">→</span>
      </a>
      <a href="/writing" class="card">
        <span class="card-label label">Writing</span>
        <h3>Ground Control</h3>
        <p>Essays on ambition, labor, discipline, loneliness, and building a life while still becoming a person.</p>
        <span class="card-arrow">→</span>
      </a>
      <a href="/projects" class="card">
        <span class="card-label label">Projects &amp; Tools</span>
        <h3>Systems I've Built</h3>
        <p>Dashboards, finance models, full-stack tools, and research pipelines — proof of motion, not perfection.</p>
        <span class="card-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Currently Working On -->
  <section class="status-strip">
    <span class="label" style="color: var(--accent); margin-right: 1rem;">Currently</span>
    <span class="status-items">
      Writing a paper on SMR financing structure &nbsp;·&nbsp;
      SmartSignals sensor pipeline &nbsp;·&nbsp;
      Training for the Philadelphia Half Marathon for the Emily Whitehead Foundation &nbsp;·&nbsp;
      Ground Control essays
    </span>
  </section>

  <!-- Emily Whitehead section -->
  <section class="emily-section">
    <div class="emily-inner">
      <p class="label" style="color: var(--accent); margin-bottom: 1rem;">Running for a reason</p>
      <h2>The Emily Whitehead Foundation</h2>
      <p>
        Emily Whitehead was the first pediatric patient to receive CAR-T cell therapy.
        She was not supposed to survive. She is now over a decade in remission.
        My dad became Executive Director of her foundation after watching Tom Whitehead tell
        that story and asking one question: <em>"how can I help?"</em> He started as a volunteer.
      </p>
      <p>
        I'm running 13.1 miles in November for the same reason. Not because I feel ready.
        Because meaningful things rarely begin with certainty — they begin when someone
        shows up before they feel qualified.
      </p>
      <a href="https://fundraisers.hakuapp.com/parker-abrantes" target="_blank" rel="noopener" class="emily-link">
        Support the fundraiser →
      </a>
    </div>
  </section>

  <!-- Proof -->
  <section class="proof-section">
    <h2>Selected Work</h2>
    <ul class="proof-list">
      <li>Built MCAP visualization pipeline for SmartSignals Run_310 traffic validation data — pairwise VRU distance analysis next.</li>
      <li>Project Manager, Panther Rocket Lab — 25+ members, ~$10K budget, 30+ design reviews. NAR Level 1 certified. Rocket named Susan.</li>
      <li>Nuclear project finance model — LCOE, DSCR, IRR across NuScale, Crane/TMI, Oklo, Vogtle. 24 passing unit tests.</li>
      <li>Biomedical simulator (FlowState) — physics-accurate bladder emptying model. No backend. Runs in the browser.</li>
      <li>Opportunity Radar — zero-dependency career dashboard connecting opportunity scoring to live application tracker.</li>
      <li>Running the Philadelphia Half Marathon to raise money for the Emily Whitehead Foundation.</li>
    </ul>
  </section>

</Base>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    max-width: 780px;
    margin: 0 auto;
    width: 100%;
  }

  .hero h1 {
    margin-bottom: 1.75rem;
    line-height: 1.15;
  }

  .hero h1 em { font-style: italic; color: var(--accent); }

  .tagline {
    font-size: 1.05rem;
    color: var(--dim);
    max-width: 58ch;
    line-height: 1.9;
    margin-bottom: 2.5rem;
  }

  .hero-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hero-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.2rem;
    transition: border-color 0.15s, color 0.15s;
  }

  .hero-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
    opacity: 1;
  }

  /* Pull quote between hero and cards */
  .pull-quote-section {
    max-width: 780px;
    margin: 0 auto;
    padding: 5rem 2rem 2rem;
  }

  .hero-pull-quote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-style: italic;
    color: var(--accent);
    line-height: 1.5;
    margin: 0;
    padding: 0;
    border: none;
    opacity: 0.85;
  }

  .cards-section {
    padding: 3rem 2rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2rem;
    color: var(--text);
    text-decoration: none;
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    opacity: 1;
  }

  .card h3 { font-size: 1.3rem; margin: 0.5rem 0 0.75rem; }
  .card p  { font-size: 0.95rem; color: var(--dim); line-height: 1.7; }

  .card-arrow {
    display: block;
    margin-top: 1.5rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 1rem;
    transition: transform 0.15s;
  }

  .card:hover .card-arrow { transform: translateX(4px); }

  .status-strip {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.1rem 2rem;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .status-items {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--dim);
    letter-spacing: 0.03em;
  }

  /* Emily section */
  .emily-section {
    padding: 5rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .emily-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .emily-inner h2 {
    margin-bottom: 1.5rem;
  }

  .emily-inner p {
    font-size: 1.05rem;
    color: var(--dim);
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }

  .emily-inner p em {
    color: var(--text);
    font-style: italic;
  }

  .emily-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }

  .emily-link:hover { opacity: 0.7; }

  .proof-section {
    max-width: 780px;
    margin: 0 auto;
    padding: 5rem 2rem 6rem;
  }

  .proof-section h2 { margin-bottom: 2rem; }

  .proof-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .proof-list li {
    font-size: 1rem;
    color: var(--dim);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.7;
  }

  .proof-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-mono);
  }
</style>
