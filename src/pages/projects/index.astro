---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const statusOrder = { active: 0, prototype: 1, research: 2, archived: 3 };
const sorted = projects.sort((a, b) => statusOrder[a.data.status] - statusOrder[b.data.status]);
---

<Base title="Projects" description="Engineering projects, research tools, and systems I've built.">
  <main class="projects-main">
    <header class="projects-header">
      <p class="label" style="color: var(--accent); margin-bottom: 1rem;">Projects</p>
      <h1>Systems I've Built</h1>
      <p class="projects-sub">
        Proof of motion, not perfection. Each project below has a real problem,
        a real build, and an honest account of what I learned.
      </p>
    </header>

    <div class="projects-grid">
      {sorted.map(p => (
        <a href={`/projects/${p.slug}`} class="project-card">
          <div class="project-card-top">
            <span class={`status-badge status-${p.data.status}`}>{p.data.status}</span>
          </div>
          <h2>{p.data.title}</h2>
          <p>{p.data.summary}</p>
          <div class="project-tags">
            {p.data.tags.slice(0, 5).map(t => <span class="tag">{t}</span>)}
          </div>
          <div class="project-tools">
            <span class="label">Tools — </span>
            <span style="font-size:0.8rem; color: var(--muted);">{p.data.tools.join(', ')}</span>
          </div>
          <span class="project-arrow">→</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  .projects-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem;
  }

  .projects-header {
    max-width: 640px;
    margin-bottom: 3.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .projects-sub {
    margin-top: 1rem;
    color: var(--dim);
    font-size: 1rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    opacity: 1;
  }

  .project-card h2 { font-size: 1.15rem; line-height: 1.3; }
  .project-card > p { font-size: 0.92rem; color: var(--dim); line-height: 1.7; }

  .project-card-top { display: flex; align-items: center; }

  .project-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.15rem 0.4rem;
  }

  .project-tools {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .project-arrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 1rem;
    margin-top: 0.25rem;
    transition: transform 0.15s;
  }

  .project-card:hover .project-arrow { transform: translateX(4px); }

  .status-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    margin-bottom: 0.25rem;
  }
  .status-active    { color: var(--accent); border: 1px solid var(--accent); }
  .status-prototype { color: #5eb8b8;       border: 1px solid #5eb8b8; }
  .status-research  { color: var(--mono);   border: 1px solid var(--mono); }
  .status-archived  { color: var(--muted);  border: 1px solid var(--muted); }
</style>
